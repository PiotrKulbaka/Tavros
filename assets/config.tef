# Common settings

editor_settings = {
    grid = {
        enabled = true
        size = 10
        step = 1
    }

    axes = {
        x_color = 0.6549 0.2196 0.3255 1.0 # 0xA73A53FF
        y_color = 0.4196 0.5569 0.1373 1.0 # 0x6BB023FF
        z_color = 0.2314 0.5137 0.7412 1.0 # 0x3A83BEFF
        thickness = 2.0
    }

    camera = {
        position = 0 0 0
        rotation = 0 0 0
        fov_y = 70.0        # Deg
        near = 0.1
        far = 5000
        orbit_dist = 12.5
    }

    gizmos = {
        enabled = true
        size = 1.0
    }
}

# ----------------------------------------------------------------
#   textures
# ----------------------------------------------------------------

# texture_name = {
#     path = "path to texture"    # required field
#     left = 0                    # optional, default 0
#     top = 0                     # optional, default 0
#     width = 0                   # optional, default 0
#     height = 0                  # optional, default 0
#     depth = 1                   # optional, default 1
#     gen_mipmaps = true          # false or true
#     type = "texture_2d"         # optional, "texture_2d", "texture_3d" or "texture_cube"; default "texture_2d"
#     pixel_format = "none"       # optional, "none", "rgba8un" ... etc; default "none"
#     array_layers = 1            # optional, default 1
#     array_rows = 0              # optional, default 0
#     array_cols = 0              # optional, default 0
# }

textures = {
    cloudy_sky = {
        path = "textures/cubemaps/cloudy.png"
        gen_mipmaps = true
        type = "texture_cube"
    }
    cloudy_sunset_sky = {
        path = "textures/cubemaps/cloudy_sunset.png"
        gen_mipmaps = true
        type = "texture_cube"
    }
    dark_sky = {
        path = "textures/cubemaps/dark.png"
        gen_mipmaps = true
        type = "texture_cube"
    }
    pure_sunset_sky = {
        path = "textures/cubemaps/pure_sunset.png"
