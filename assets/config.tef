    }
    sunset_sky = {
        path = "textures/cubemaps/sunset.png"
        gen_mipmaps = true
        type = "texture_cube"
    }
}

# ----------------------------------------------------------------
#   render targets
# ----------------------------------------------------------------

main_offscreen_rendertarget = {
    color = {
        base_color = {
            format = "rgba8"
            load = "clear"
            store = "store"
            clear = 0.0 0.0 0.0 0.0
        }
    }

    depth = {
        format = "depth32f"
        load = "clear"
        store = "store"
        clear = 1.0
    }
}

rt1 = {
