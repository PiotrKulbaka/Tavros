pipeline_base = {
    vertex_shader = ""
    fragment_shader = ""

    attrubutes = {
        type = "scalar"                             # "scalar" "vec2" "vec3" "vec4" "mat2" "mat2x3" "mat2x4" "mat3x2" "mat3" "mat3x4" "mat4x2" "mat4x3" "mat4"
        format = "f32"                              # "u8" "i8" "u16" "i16" "u32" "i32" "f16" "f32" "f64"
        normalize = false
        location = 0
        stride = 0
        offset = 0
        instance_divisor = 0
    }

    blend_state = {
        blend_enabled = false
        src_color_factor = "src_alpha"              # "zero" "one" "src_color" "one_minus_src_color" "dst_color" "one_minus_dst_color"
                                                    # "src_alpha" "one_minus_src_alpha" "dst_alpha" "one_minus_dst_alpha"

        dst_color_factor = "one_minus_src_alpha"    # "zero" "one" "src_color" "one_minus_src_color" "dst_color" "one_minus_dst_color"
                                                    # "src_alpha" "one_minus_src_alpha" "dst_alpha" "one_minus_dst_alpha"

        color_blend_op = "add"                      # "add" "subtract" "reverse_subtract" "min" "max"

        src_alpha_factor = "one"                    # "zero" "one" "src_color" "one_minus_src_color" "dst_color" "one_minus_dst_color"
                                                    # "src_alpha" "one_minus_src_alpha" "dst_alpha" "one_minus_dst_alpha"

        dst_alpha_factor = "one_minus_src_alpha"    # "zero" "one" "src_color" "one_minus_src_color" "dst_color" "one_minus_dst_color"
                                                    # "src_alpha" "one_minus_src_alpha" "dst_alpha" "one_minus_dst_alpha"

        alpha_blend_op = "add"                      # "add" "subtract" "reverse_subtract" "min" "max"
        mask = "red" "green" "blue" "alpha"         # "red" "green" "blue" "alpha"
    }

    depth_stencil_state = {
        depth_test_enable = false
        depth_write_enable = false
        depth_compare = "off"               # "off" "less" "equal" "less_equal" "greater" "greater_equal" "not_equal" "always"
        stencil_test_enable = false
        stencil_front = {
            read_mask = 0xFF
            write_mask = 0xFF
            reference_value = 0
            compare = "always"
            stencil_fail_op = "keep"
            depth_fail_op = "keep"
            pass_op = "keep"
        }
        stencil_back = {
            read_mask = 0xFF
            write_mask = 0xFF
            reference_value = 0
            compare = "always"
            stencil_fail_op = "keep"
            depth_fail_op = "keep"
            pass_op = "keep"
        }
    }

    topology = "points"                 # "points" "lines" "line_strip" "triangles" "triangle_strip" "triangle_fan"

    rasterizer = {
        cull = "off"                    # "off" "front" "back"
        face = "counter_clockwise"      # "clockwise" "counter_clockwise"
        polygon = "fill"                # "fill" "lines" "points"
        depth_clamp_enable = false
        depth_clamp_near = 0.0
        depth_clamp_far = 1.0
        depth_bias_enable = false
        depth_bias = 0.0
        depth_bias_factor = 0.0
        depth_bias_clamp = 0.0
        scissor_enable = false
    }
}


